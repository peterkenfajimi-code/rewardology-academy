# Site (local dev)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production on Vercel:
# NEXT_PUBLIC_SITE_URL=https://rewardologyacademy.com

# Supabase (auth, quizzes + XP, course progress)
# After creating a project, run supabase/schema.sql in the SQL Editor.
# Production auth redirect: https://rewardologyacademy.com/auth/callback
# Local redirect: http://localhost:3000/auth/callback
# Optional — run scripts/apply-supabase-schema.mjs (never commit this token)
# Optional — run npm run configure:supabase-auth for production Site URL + redirects
# SUPABASE_ACCESS_TOKEN=

# Google OAuth (https://supabase.com/docs/guides/auth/social-login/auth-google)
# Redirect URI in Google Cloud: https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# NEXT_PUBLIC_GOOGLE_OAUTH_ENABLED=true
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Sanity CMS (articles, courses)
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-01-01

# ElevenLabs (premium read-aloud — strongly recommended for production)
# Create a key at https://elevenlabs.io → Profile → API Keys
# Then run: npm run configure:netlify-env
ELEVENLABS_API_KEY=
# Sarah (warm US female) — or try Charlotte (XB0fDUnXU5powFXDhCwa) for UK professional tone
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Homepage news — Google News RSS + direct publication feeds (no API key required)
# Optional NewsData.io enrichment when quota available (https://newsdata.io)
# NEWSDATA_API_KEY=

# Resend (Supabase Auth email)
# Verify rewardologyacademy.com at https://resend.com/domains → add DNS in Netlify
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=noreply@rewardologyacademy.com
# RESEND_SENDER_NAME=Rewardology Academy
# Then: npm run configure:resend-smtp (requires SUPABASE_ACCESS_TOKEN above)
# Optional on Netlify (server-only, for /setup health checks): SUPABASE_ACCESS_TOKEN, RESEND_API_KEY
